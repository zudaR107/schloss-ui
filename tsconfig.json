{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "declaration": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "erasableSyntaxOnly": true,
    "noEmit": true,
    // tsup's dts bundler (rollup-plugin-dts) always injects a `baseUrl`
    // into the program it type-checks with, even though we don't set one
    // ourselves - TS 6.0 flags any baseUrl as deprecated (TS5101).
    "ignoreDeprecations": "6.0"
  },
  "include": ["src"]
}
